{
  "version": 3,
  "changelog": {
    "2": "Initial release with em-dash classifier and ad-token filters.",
    "3": "typography_noise no longer fires on em-dash; headline_like restricted to numeric-prefix patterns only."
  },
  "thresholds": {
    "human": 25,
    "suspect": 60
  },
  "weights": {
    "exact_ad_layout_token": 100,
    "sponsored_sentinel": 35,
    "typography_noise": 8,
    "title_fragment": 6,
    "headline_like": 8,
    "parenthetical_dash": 14,
    "serial_dash": 20,
    "serial_dash_step": 2,
    "list_descriptor_dash": 18,
    "heading_style_dash": 16,
    "colon_candidate_dash": 14,
    "comma_candidate_dash": 10,
    "single_dash_fallback": 10,
    "multi_dash_fallback": 16,
    "multi_dash_step": 4
  },
  "sentinel_words": ["sponsored", "promoted", "partner content", "native ad", "paid post"],
  "regex_patterns": {
    "exact_em_dash": "\\u2014",
    "headline_like": "^(\\d+\\s+)[A-Z]"
  }
}
